# ============================================================
# Variables de entorno — copiar este archivo a .env
#   cp .env.example .env
# ============================================================

# Base de datos PostgreSQL
DB_NAME=inventory_db
DB_USER=inventory_user
DB_PASSWORD=inventory_pass

# JWT — cambiar por una clave aleatoria segura en producción
# Generar con: openssl rand -hex 32
JWT_SECRET=mySecretKeyForJWTTokenThatIsAtLeast256BitsLong1234567890ABCDEF
JWT_EXPIRATION=86400000

# Perfil de Spring Boot (no cambiar para uso con Docker)
SPRING_PROFILE=docker
